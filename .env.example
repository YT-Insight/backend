# Copy this file to .env and fill in every value before running the project

# Django
SECRET_KEY=your-long-random-secret-key-here
DEBUG=True

# PostgreSQL
DATABASE_NAME=yt_insight
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis (also used by Celery)
REDIS_URL=redis://localhost:6379/0

# YouTube Data API v3
# Enable at https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=

# DeepSeek AI
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Stripe
# Test keys start with sk_test_ / pk_test_
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Frontend URL (used in Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000

# Production only
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
