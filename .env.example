# Copy this file to .env, fill in every value, and do not commit the real .env file

# Django
SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=True

# PostgreSQL
DATABASE_NAME=yt_insight
DATABASE_USER=postgres
DATABASE_PASSWORD=replace-with-a-strong-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis (also used by Celery)
REDIS_URL=redis://localhost:6379/0

# YouTube Data API v3
# Enable at https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=replace-if-you-enable-youtube-integration

# DeepSeek AI
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=replace-if-you-enable-deepseek-integration

# Stripe
# Test keys start with sk_test_ / pk_test_
STRIPE_SECRET_KEY=replace-if-you-enable-stripe
STRIPE_WEBHOOK_SECRET=replace-if-you-enable-stripe
STRIPE_BASIC_PRICE_ID=replace-if-you-enable-stripe
STRIPE_PRO_PRICE_ID=replace-if-you-enable-stripe

# Frontend URL (used in Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000

# Production only
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
